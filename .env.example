# ---- xAI (required) ----
XAI_API_KEY=xai-...
XAI_MANAGEMENT_KEY=xai-token-...        # for creating the knowledge base
XAI_COLLECTION_ID=                      # filled in by kit/scripts/setup-kb.mjs

# ---- Google Calendar booking (required for booking) ----
# Base64 of a Google service-account JSON with Calendar access (see docs/CALENDAR.md)
GOOGLE_SA_JSON_B64=
GOOGLE_IMPERSONATE=you@yourdomain.com   # user the service account acts as
DEMO_CALENDAR_ID=                        # calendar to write bookings to

# ---- Phone (optional: inbound + outbound) ----
TWILIO_SID=AC...
TWILIO_AUTH=...
TWILIO_NUMBER=+1...
BOOK_URL=https://your-web-app.up.railway.app/api/book   # bridge posts bookings here
BRIDGE_URL=https://your-bridge.up.railway.app           # web /demo posts outbound calls here
